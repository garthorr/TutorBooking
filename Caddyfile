# Caddy reverse proxy configuration for TutorBooking
#
# FOR LOCAL TESTING: Use the localhost block below (active by default)
# FOR PRODUCTION: Replace YOUR_DOMAIN_HERE with your domain and comment out localhost

# ═══════════════════════════════════════════════════════════════════════════
# LOCALHOST (for local testing)
# ═══════════════════════════════════════════════════════════════════════════
localhost, http://localhost {
    # Proxy API requests to Express server
    handle /api/* {
        reverse_proxy server:5000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Proxy auth requests to Express server
    handle /auth/* {
        reverse_proxy server:5000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Everything else goes to nginx (React app)
    handle {
        reverse_proxy client:80 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}

# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION (replace YOUR_DOMAIN_HERE with your actual domain)
# ═══════════════════════════════════════════════════════════════════════════
