# Server Configuration
PORT=5000
NODE_ENV=development
TIMEZONE=America/Chicago

# Drive Time Configuration
# Drive times between schools are configured in server/schoolConfig.js
# The system automatically adds 5 minutes for walking/parking
# Times are rounded to the nearest 5 minutes

# Google Calendar API Configuration
# You can connect via web interface (recommended) or manual setup

# Required for both web and manual setup:
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
GOOGLE_CALENDAR_ID=primary

# Optional - for manual setup only (not needed if using web interface):
# GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# ── Admin authentication ──────────────────────────────────────────────────────
# Required: password hash for the admin panel login
#
# IMPORTANT: bcrypt hashes contain $ signs. Docker Compose env_file treats $ as a
# variable reference, so each $ must be written as $$ in this file.
#
# Easiest approach — generate inside the running container (no escaping needed):
#   docker compose exec server node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
#
# If generating on the host, escape every $ as $$ when pasting here:
#   $2b$12$abc...  →  $$2b$$12$$abc...
#
ADMIN_PASSWORD_HASH=$$2b$$12$$examplehashreplacethiswithyourownescapeddollarsigns

# Required: secret used to sign admin session JWTs
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Security — token encryption ───────────────────────────────────────────────
# Encryption key for storing OAuth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, will use a default key (NOT SECURE for production)
ENCRYPTION_KEY=change-this-to-a-random-string-in-production

# Google Maps API key - enables address autocomplete in the admin Schools UI
# Enable "Maps JavaScript API", "Places API", and "Geocoding API" in Google Cloud Console
# If not set, address autocomplete is disabled (manual entry still works)
GOOGLE_MAPS_API_KEY=your_maps_api_key_here
