# ── Required ──────────────────────────────────────────────────────────────────
# Bcrypt hash of the admin password. Generate with:
#   node -e "require('bcryptjs').hash('YourPassword123', 10).then(console.log)"
# Password must be 12+ chars with uppercase, lowercase, and a digit.
ADMIN_PASSWORD_HASH=

# Secret used to sign admin JWT tokens. Use a long random string.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Key used to encrypt stored Google OAuth tokens. Use a long random string.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# ── Optional ──────────────────────────────────────────────────────────────────
TIMEZONE=America/Chicago
GOOGLE_MAPS_API_KEY=
GOOGLE_REFRESH_TOKEN=
PORT=5000
DATA_DIR=/app/data
TRUST_PROXY=
CORS_ORIGINS=
