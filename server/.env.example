# Required
ADMIN_PASSWORD_HASH=
JWT_SECRET=
ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# Optional
TIMEZONE=America/Chicago
GOOGLE_MAPS_API_KEY=
GOOGLE_REFRESH_TOKEN=
PORT=5000
DATA_DIR=/app/data
TRUST_PROXY=
CORS_ORIGINS=

# Optional — transactional email (confirmations, reschedule/cancel, reminders).
# Leave SMTP_HOST blank to disable email entirely (Google Calendar invites still work).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# Public base URL used to build manage links inside emails, e.g. https://yourdomain.com
PUBLIC_BASE_URL=
