# ── Docker Compose file selection ────────────────────────────────────────────
# Controls which compose files are merged when running `docker compose up`.
# Copy this file to .env and set COMPOSE_FILE for your environment.
# (.env is gitignored — each server has its own copy)
#
# Oracle / local dev (default — override.yml auto-loaded, no need to set this):
# COMPOSE_FILE=docker-compose.yml:docker-compose.override.yml
#
# Production with Traefik (set this on your production server):
# COMPOSE_FILE=docker-compose.yml:docker-compose.traefik.yml
#
# With this set, `docker compose up -d` does the right thing on every server
# with no -f flags needed.
COMPOSE_FILE=docker-compose.yml:docker-compose.override.yml
