# Server Configuration
PORT=5000
NODE_ENV=development
TIMEZONE=America/Chicago

# Drive Time Configuration
# Drive times between schools are configured in server/schoolConfig.js
# The system automatically adds 5 minutes for walking/parking
# Times are rounded to the nearest 5 minutes

# Google Calendar API Configuration
# Follow the setup guide in README.md to obtain these credentials

# OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# OAuth 2.0 Client Secret from Google Cloud Console
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Redirect URI (use this when setting up OAuth)
GOOGLE_REDIRECT_URI=http://localhost:5000/oauth2callback

# Refresh Token (obtained after OAuth flow)
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Calendar ID (use 'primary' for your main calendar or a specific calendar ID)
GOOGLE_CALENDAR_ID=primary
