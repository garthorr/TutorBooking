# Server Configuration
PORT=5000
NODE_ENV=development
TIMEZONE=America/Chicago

# Drive Time Configuration
# Drive times between schools are configured in server/schoolConfig.js
# The system automatically adds 5 minutes for walking/parking
# Times are rounded to the nearest 5 minutes

# Google Calendar API Configuration
# You can connect via web interface at /admin (recommended) or manual setup

# Required for both web and manual setup:
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
GOOGLE_CALENDAR_ID=primary

# Optional - for manual setup only (not needed if using web interface):
# GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Security - Encryption key for storing OAuth tokens
# Generate a random string for production (recommended)
# If not set, will use a default key (NOT SECURE for production)
ENCRYPTION_KEY=change-this-to-a-random-string-in-production

# JWT secret used to sign admin session tokens.
# Must be set to a strong, unique value (>= 16 chars). The server refuses to
# start in production with the default/short value.
JWT_SECRET=change-this-to-a-long-random-string

# CORS - comma-separated list of allowed origins for production
# (localhost/127.0.0.1 are always allowed for local development)
# CORS_ORIGINS=https://booking.example.com

# Email / appointment notifications (optional)
# When SMTP_HOST is unset, transactional email and reminders are disabled and
# the app relies on Google Calendar invites only.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false           # true for port 465, false for STARTTLS (587)
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# EMAIL_FROM="Tutoring <no-reply@example.com>"
# Public base URL used to build manage (reschedule/cancel) links in emails
# PUBLIC_BASE_URL=https://booking.example.com

# CAPTCHA on the public booking form (optional)
# Supports Cloudflare Turnstile (default) or hCaptcha. When the site key and
# secret are both set, the booking form requires a solved CAPTCHA. Leave unset
# to disable (e.g. for local development).
# CAPTCHA_PROVIDER=turnstile   # turnstile | hcaptcha
# CAPTCHA_SITE_KEY=your_public_site_key
# CAPTCHA_SECRET_KEY=your_private_secret_key
