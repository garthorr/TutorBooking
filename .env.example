# This file is read by Docker Compose for variable substitution.
# Copy to .env — it is gitignored so each server has its own copy.
#
# docker-compose.yml        — production (Traefik required)
# docker-compose.override.yml — auto-loaded for dev; adds SSH-tunnel port,
#                               sets NODE_ENV=development
#
# Production:  docker compose up -d            (override.yml excluded if not present)
# Dev:         docker compose up -d            (override.yml auto-loaded)
#
# To run production on a machine that also has override.yml checked out:
#   docker compose -f docker-compose.yml up -d
